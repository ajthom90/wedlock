# ---------------------------------------------------------------------------
# Build context shrinkage. Every file not listed here gets shipped to the
# BuildKit daemon on every build — keep this tight.
# ---------------------------------------------------------------------------

# Version control
.git
.gitignore
.gitattributes
.github
.gitea

# Docker artifacts
.dockerignore
Dockerfile*
docker-compose*.yml

# Node / build outputs
node_modules
.next
.npm
.pnpm-store
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# TypeScript incremental cache (regenerated inside the image)
tsconfig.tsbuildinfo

# Local Prisma artifacts — re-generated in the builder
prisma/dev.db
prisma/dev.db-journal
prisma/migrations/dev

# Docs and specs — not needed at runtime
docs
*.md
!prisma/README.md

# Scripts folder (release/deploy helpers only used outside the container)
scripts

# Test configuration (devDep-only tooling)
vitest.config.ts
playwright.config.ts
playwright-report
test-results
coverage

# Editor / OS droppings
.vscode
.idea
.DS_Store
*.swp
*.swo

# Env files — never embed secrets into images
.env
.env.local
.env.*.local

# Local data directory (mounted volume at runtime)
data

# Claude / tooling state
.claude
.playwright-mcp
