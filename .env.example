# Copy this file to `.env` and fill in the values for your environment.
# `.env` is gitignored — it stays local to your checkout.

# Docker registries to push images to. Space-separated list.
# Example: "ghcr.io/your-user/wedlock docker.io/your-user/wedlock"
# The first entry is also used for the buildx layer cache.
#
# Leave unset to skip local Docker builds entirely — the GitHub Actions
# workflow will publish to GHCR automatically when `./scripts/docker.sh
# bump-*` pushes a git tag.
#DOCKER_REGISTRIES="ghcr.io/YOUR-USERNAME/wedlock"

# Optional: trailer appended to the "Bump to vX.Y.Z" commit produced by
# bump-* commands. Leave unset for no trailer.
#COMMIT_TRAILER="Co-Authored-By: Your Collaborator <them@example.com>"
